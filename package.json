{
  "name": "brid-utils",
  "version": "1.0.0",
  "private": false,
  "description": "j'ai rien mis",
  "homepage": "https://victorwmb.github.io/CICD",
  "bugs": {
    "url": "https://github.com/victorwmb/CICD/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victorwmb/CICD.git"
  },
  "license": "ISC",
  "author": "Moi",
  "main": "dist/App.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "start": "./node_modules/.bin/react-scripts start",
    "build": "./node_modules/.bin/react-scripts build",
    "test": "./node_modules/.bin/react-scripts test --coverage --collectCoverageFrom=\"src/**/*.{js,jsx}\" --collectCoverageFrom=\"!src/reportWebVitals.js\" --collectCoverageFrom=\"!src/index.js\" --watchAll=false",
    "eject": "./node_modules/.bin/react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "./node_modules/.bin/gh-pages -d build",
    "build-npm": "rm -rf dist && mkdir dist && NODE_ENV=production ./node_modules/.bin/babel src --out-dir dist --copy-files",
    "jsdoc": "./node_modules/.bin/jsdoc -c ./jsdoc.config.json -r -d ./docs"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-scripts": "^5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "gh-pages": "^6.3.0",
    "jsdoc": "^4.0.5"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
